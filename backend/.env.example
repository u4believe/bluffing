# --- 0G Chain ---
ZEROG_CHAIN_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_CHAIN_ID=16602
ZEROG_SETTLEMENT_CONTRACT_ADDRESS=0xPLACEHOLDER
ZEROG_SETTLER_PRIVATE_KEY=0xPLACEHOLDER

# --- 0G Storage ---
ZEROG_STORAGE_RPC_URL=https://indexer-storage-testnet.0g.ai
ZEROG_STORAGE_PRIVATE_KEY=0xPLACEHOLDER_SAME_OR_DIFFERENT_KEY

# --- Auth / persistence ---
# Upstash Redis (via Vercel's Redis Marketplace integration) holds agent keys,
# table state pointers, ELO cache. Vercel KV itself is deprecated/migrated to
# Upstash — connect via Vercel Dashboard -> Storage -> Redis integration,
# which will populate these automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- WebSocket game server (deployed separately, NOT on Vercel) ---
# e.g. Railway / Fly.io / Render URL
WS_SERVER_PUBLIC_URL=wss://bluffline-ws.up.railway.app
WS_SERVER_INTERNAL_SHARED_SECRET=PLACEHOLDER_SHARED_SECRET

# --- Misc ---
NODE_ENV=development
